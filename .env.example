# Переменные окружения для Docker контейнера
# Скопируй в .env и заполни свои значения

# Обязательные переменные
HH_PROFILE_ID=YOUR_PROFILE_ID_HERE

# Пути
CONFIG_DIR=/app/config
LOG_DIR=/app/config

# Параметры приложения
APP_ENV=production  # development, staging, production
LOG_LEVEL=INFO

# Admin Panel
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_PORT=8000

# Pyautogui/Playwright опции
HEADLESS=true
BROWSER_TIMEOUT=30000

# Прокси (опционально)
# HTTP_PROXY=
# HTTPS_PROXY=
# SOCKS_PROXY=

# Таймзона
TZ=Europe/Moscow
